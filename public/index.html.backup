<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SoundCloud to Apple Music Sync</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;600;700&display=swap" rel="stylesheet">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --primary: #FF5500;
            --bg: #0a0a0a;
            --surface: #1a1a1a;
            --text: #f5f5f5;
            --text-muted: #a0a0a0;
            --border: #2a2a2a;
            --success: #00d084;
            --danger: #ff3333;
            --accent: #00d4ff;
        }
        html, body { width: 100%; height: 100%; margin: 0; padding: 0; }
        body { font-family: 'IBM Plex Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.5; display: flex; flex-direction: column; overflow: hidden; }
        .app-container { display: flex; flex-direction: column; height: 100vh; }
        .header-bar { background: linear-gradient(135deg, rgba(255, 85, 0, 0.1) 0%, transparent 100%); border-bottom: 1px solid var(--border); padding: 16px 24px; display: flex; justify-content: space-between; align-items: center; }
        .header-title { font-size: 1.2rem; font-weight: 700; color: var(--primary); }
        .header-badge { background: var(--primary); color: white; padding: 4px 12px; border-radius: 12px; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
        .main-content { flex: 1; display: flex; flex-direction: column; overflow: hidden; gap: 1px; background: var(--border); padding: 1px; }
        .instructions-panel { background: var(--surface); border-bottom: 1px solid var(--border); overflow: hidden; transition: max-height 0.3s ease; max-height: 120px; }
        .instructions-panel.hidden { max-height: 0; border-bottom: none; }
        .instructions-inner { padding: 20px 24px; }
        .instructions-header { display: flex; justify-content: space-between; align-items: center; cursor: pointer; user-select: none; }
        .instructions-title { font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--primary); }
        .toggle-btn { background: none; border: none; color: var(--primary); font-size: 1.5rem; cursor: pointer; padding: 0; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; }
        .instructions-content { font-size: 0.85rem; line-height: 1.6; color: var(--text-muted); margin-top: 12px; padding-top: 12px; border-top: 1px solid var(--border); }
        .instructions-content ol { margin-left: 20px; }
        .instructions-content li { margin-bottom: 6px; }
        .modal { display: none; position: fixed; z-index: 10000; left: 0; top: 0; width: 100%; height: 100%; background-color: rgba(0, 0, 0, 0.8); }
        .modal.show { display: flex; align-items: center; justify-content: center; }
        .modal-content { background-color: var(--surface); padding: 30px; border: 1px solid var(--border); border-radius: 6px; width: 90%; max-width: 700px; max-height: 80vh; overflow-y: auto; color: var(--text); }
        .modal-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; border-bottom: 1px solid var(--border); padding-bottom: 15px; }
        .modal-header h2 { font-size: 1.3rem; color: var(--primary); margin: 0; }
        .close-btn { background: none; border: none; font-size: 1.5rem; color: var(--text-muted); cursor: pointer; padding: 0; width: 30px; height: 30px; display: flex; align-items: center; justify-content: center; }
        .close-btn:hover { color: var(--text); }
        .guide-step { margin-bottom: 20px; padding-bottom: 20px; border-bottom: 1px solid var(--border); }
        .guide-step:last-child { border-bottom: none; }
        .guide-step-number { display: inline-block; background: var(--primary); color: white; width: 30px; height: 30px; border-radius: 50%; text-align: center; line-height: 30px; font-weight: 700; margin-right: 10px; }
        .guide-step-title { font-weight: 700; color: var(--text); display: inline; }
        .guide-step-content { margin-top: 8px; margin-left: 40px; font-size: 0.9rem; color: var(--text-muted); }
        .code-block { background: rgba(0, 0, 0, 0.5); padding: 10px; border-radius: 3px; font-family: 'IBM Plex Mono', monospace; font-size: 0.85rem; margin: 8px 0; color: var(--accent); word-break: break-all; border-left: 3px solid var(--primary); }
        .highlight { background: rgba(255, 85, 0, 0.2); padding: 2px 4px; border-radius: 2px; }
        .info-badge { background: rgba(255, 85, 0, 0.2); border: 1px solid var(--primary); padding: 6px 10px; border-radius: 3px; margin-bottom: 12px; font-size: 0.7rem; color: var(--primary); font-weight: 600; text-transform: uppercase; }
        .panels-container { flex: 1; display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--border); overflow: hidden; }
        .panel { background: var(--surface); display: flex; flex-direction: column; overflow: hidden; }
        .panel-header { padding: 20px 24px; border-bottom: 1px solid var(--border); background: linear-gradient(135deg, rgba(255, 85, 0, 0.05) 0%, transparent 100%); }
        .panel-header h2 { font-size: 1.1rem; font-weight: 700; margin: 0; letter-spacing: -0.5px; }
        .panel-header p { font-size: 0.8rem; color: var(--text-muted); margin: 4px 0 0 0; }
        .panel-content { flex: 1; overflow-y: auto; padding: 20px 24px; }
        .form-group { margin-bottom: 18px; }
        .form-group label { display: block; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 6px; }
        input[type="text"] { width: 100%; padding: 10px 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border); border-radius: 4px; color: var(--text); font-family: 'IBM Plex Mono', monospace; font-size: 0.9rem; transition: all 0.2s ease; }
        input[type="text"]:focus { outline: none; border-color: var(--primary); background: rgba(255, 85, 0, 0.08); }
        input::placeholder { color: var(--text-muted); }
        .path-container { display: flex; gap: 8px; margin-bottom: 8px; }
        .path-container input { flex: 1; }
        .button { padding: 10px 16px; border: none; border-radius: 4px; font-family: 'IBM Plex Sans', sans-serif; font-size: 0.9rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; cursor: pointer; transition: all 0.2s ease; width: 100%; margin-bottom: 8px; }
        .button-small { width: auto; padding: 10px 16px; }
        .button-primary { background: var(--primary); color: white; }
        .button-primary:hover:not(:disabled) { background: #ff6622; transform: translateY(-1px); }
        .button-secondary { background: rgba(255, 255, 255, 0.08); color: var(--text); border: 1px solid var(--border); }
        .button-secondary:hover:not(:disabled) { background: rgba(255, 255, 255, 0.12); }
        .button:disabled { opacity: 0.5; cursor: not-allowed; }
        .status-box { background: rgba(255, 255, 255, 0.03); border: 1px solid var(--border); border-radius: 4px; padding: 14px; margin-bottom: 16px; font-family: 'IBM Plex Mono', monospace; }
        .status-label { font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1px; color: var(--text-muted); margin-bottom: 6px; }
        .status-value { font-size: 1rem; color: var(--primary); }
        .status-value.idle { color: var(--text-muted); }
        .status-value.syncing { color: var(--accent); animation: pulse 1.5s infinite; }
        .status-value.success { color: var(--success); }
        .status-value.error { color: var(--danger); }
        @keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.6; } }
        .toggle-terminal { display: inline-block; padding: 8px 12px; background: rgba(255, 255, 255, 0.05); border: 1px solid var(--border); border-radius: 4px; cursor: pointer; font-size: 0.85rem; color: var(--text); margin-bottom: 12px; user-select: none; }
        .toggle-terminal:hover { background: rgba(255, 255, 255, 0.08); }
        .terminal { background: rgba(0, 0, 0, 0.5); border: 1px solid var(--border); border-radius: 4px; padding: 12px; height: 200px; overflow-y: auto; margin-bottom: 12px; font-family: 'IBM Plex Mono', monospace; font-size: 0.85rem; color: var(--text-muted); display: none; flex-direction: column; }
        .terminal.visible { display: flex; }
        .terminal-line { margin-bottom: 3px; word-break: break-word; line-height: 1.3; }
        .terminal-line.success { color: var(--success); }
        .terminal-line.error { color: var(--danger); }
        .alert { position: fixed; bottom: 0; left: 0; right: 0; padding: 16px 24px; text-align: center; font-weight: 600; z-index: 1000; transform: translateY(150px); transition: transform 0.3s ease; }
        .alert.show { transform: translateY(0); }
        .alert.success { background: var(--success); color: #000; }
        .alert.error { background: var(--danger); color: white; }
        .help-text { font-size: 0.8rem; color: var(--text-muted); margin-top: 4px; }
        .required { color: var(--danger); }
        @media (max-width: 1200px) { .panels-container { grid-template-columns: 1fr; } }
    </style>
</head>
<body>
    <div class="app-container">
        <div class="header-bar">
            <div class="header-title">SoundCloud to Apple Music Sync</div>
            <div class="header-badge">macOS Only</div>
        </div>

        <div class="main-content">
            <div class="instructions-panel" id="instructionsPanel">
                <div class="instructions-inner">
                    <div class="instructions-header" onclick="toggleInstructions()">
                        <div class="instructions-title">Quick Start</div>
                        <button class="toggle-btn" id="toggleBtn">−</button>
                    </div>
                    <div class="instructions-content">
                        <ol>
                            <li>Get your SoundCloud token (click "How to Get?" button below)</li>
                            <li>Paste token and playlist URL</li>
                            <li>Click "Start Sync"</li>
                            <li>Check Apple Music for your new songs</li>
                        </ol>
                    </div>
                </div>
            </div>

            <div class="panels-container">
                <div class="panel">
                    <div class="panel-header">
                        <h2>Configuration</h2>
                        <p>Set up your sync</p>
                    </div>
                    <div class="panel-content">
                        <button class="button button-secondary" onclick="openSoundCloudLogin()">Get Token</button>
                        <div class="form-group" style="background: rgba(255, 85, 0, 0.1); border: 1px solid var(--primary); border-radius: 6px; padding: 15px; margin-bottom: 18px;">
                            <div style="font-size: 0.9rem; font-weight: 700; color: var(--primary); margin-bottom: 12px;">Steps to Get Your Token:</div>
                            <ol style="margin-left: 20px; font-size: 0.85rem; color: var(--text-muted); line-height: 1.8;">
                                <li>Click "Get Token" above to open SoundCloud</li>
                                <li>Log in to your account</li>
                                <li>Press Cmd+Option+I to open DevTools</li>
                                <li>Go to Application tab</li>
                                <li>Click Cookies in sidebar</li>
                                <li>Click https://soundcloud.com</li>
                                <li>Search for "oa" in the cookies</li>
                                <li>Copy the Value and paste below</li>
                            </ol>
                        </div>

                        <div class="form-group">
                            <label>SoundCloud Auth Token <span class="required">*</span></label>
                            <input type="text" id="authToken" placeholder="Paste your token here">
                            <div class="help-text">Get from browser DevTools (see guide above)</div>
                        </div>

                        <div class="form-group">
                            <label>SoundCloud Playlist URL <span class="required">*</span></label>
                            <input type="text" id="playlistUrl" placeholder="https://soundcloud.com/username/sets/playlist">
                            <div class="help-text">Direct playlist link only</div>
                        </div>

                        <div class="form-group">
                            <label>Album Name <span class="required">*</span></label>
                            <input type="text" id="albumName" placeholder="Name for your playlist in Apple Music">
                        </div>

                        <div class="form-group">
                            <label>Album Artist</label>
                            <input type="text" id="albumArtist" placeholder="Artist name (optional)">
                        </div>

                        <div class="info-badge">New folder required for each album</div>

                        <div class="form-group">
                            <label>Download Path <span class="required">*</span></label>
                            <div class="path-container">
                                <input type="text" id="downloadPath" placeholder="/Users/username/Music/Album">
                                <button class="button button-secondary button-small" onclick="selectDownloadPath()">Browse</button>
                            </div>
                            <div class="help-text">Click Browse to choose folder for this album</div>
                        </div>

                        <button class="button button-secondary" onclick="saveConfig()">Save Config</button>
                        <button class="button button-primary" onclick="startSync()" id="syncBtn">Start Sync</button>
                    </div>
                </div>

                <div class="panel">
                    <div class="panel-header">
                        <h2>Status</h2>
                        <p>Live sync information</p>
                    </div>
                    <div class="panel-content">
                        <div class="status-box">
                            <div class="status-label">State</div>
                            <div class="status-value idle" id="statusText">Ready</div>
                        </div>

                        <div class="toggle-terminal" onclick="toggleTerminal()">
                            > View Terminal Output
                        </div>

                        <div class="terminal" id="terminal"></div>

                        <div class="status-box" id="completeBox" style="display: none;">
                            <div class="status-label">Result</div>
                            <div class="status-value success">Sync Complete</div>
                            <div class="help-text" style="margin-top: 8px; color: var(--text-muted);">
                                Check Apple Music app for new songs.
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div id="guideModal" class="modal">
        <div class="modal-content">
            <div class="modal-header">
                <h2>How to Get Your SoundCloud Token</h2>
                <button class="close-btn" onclick="closeGuide()">×</button>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">1</span>
                <span class="guide-step-title">Open a Web Browser</span>
                <div class="guide-step-content">Go to soundcloud.com and log in to your account</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">2</span>
                <span class="guide-step-title">Open Developer Tools</span>
                <div class="guide-step-content">Press F12 on Windows or Cmd + Option + I on Mac</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">3</span>
                <span class="guide-step-title">Go to Network Tab</span>
                <div class="guide-step-content">Click the Network tab at the top of the DevTools panel</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">4</span>
                <span class="guide-step-title">Filter for API Requests</span>
                <div class="guide-step-content">Type <strong>api</strong> in the filter box to see only API requests</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">5</span>
                <span class="guide-step-title">Trigger a Request</span>
                <div class="guide-step-content">Refresh the SoundCloud page or navigate to a playlist</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">6</span>
                <span class="guide-step-title">Find Authorization Header</span>
                <div class="guide-step-content">Click any API request and find Request Headers section</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">7</span>
                <span class="guide-step-title">Copy Your Token</span>
                <div class="guide-step-content">Look for Authorization header and copy the token after "token="</div>
            </div>

            <div class="guide-step">
                <span class="guide-step-number">8</span>
                <span class="guide-step-title">Paste Token</span>
                <div class="guide-step-content">Close this guide and paste your token in the SoundCloud Auth Token field</div>
            </div>
        </div>
    </div>

    <div id="alert" class="alert"></div>

    <script>
        const API_BASE = 'http://localhost:3001/api';

        function loadConfigOnStartup() {
            fetch(API_BASE + '/config/get')
                .then(res => res.json())
                .then(config => {
                    if (config.auth_token) document.getElementById('authToken').value = config.auth_token;
                    if (config.playlist_url) document.getElementById('playlistUrl').value = config.playlist_url;
                    if (config.album_name) document.getElementById('albumName').value = config.album_name;
                    if (config.album_artist) document.getElementById('albumArtist').value = config.album_artist;
                    if (config.download_path) document.getElementById('downloadPath').value = config.download_path;
                })
                .catch(() => {});
        }

        window.addEventListener('DOMContentLoaded', loadConfigOnStartup);

        function toggleInstructions() {
            const panel = document.getElementById('instructionsPanel');
            const btn = document.getElementById('toggleBtn');
            panel.classList.toggle('hidden');
            btn.textContent = panel.classList.contains('hidden') ? '+' : '−';
        }

        function openGuide() {
            document.getElementById('guideModal').classList.add('show');
        }

        function closeGuide() {
            document.getElementById('guideModal').classList.remove('show');
        }

        window.onclick = function(event) {
            if (event.target == document.getElementById('guideModal')) {
                document.getElementById('guideModal').classList.remove('show');
            }
        }

        async function selectDownloadPath() {
            const path = await window.electronAPI.selectDirectory();
            if (path) document.getElementById('downloadPath').value = path;
        }

        function saveConfig() {
            const config = {
                authToken: document.getElementById('authToken').value,
                playlistUrl: document.getElementById('playlistUrl').value,
                albumName: document.getElementById('albumName').value,
                albumArtist: document.getElementById('albumArtist').value,
                downloadPath: document.getElementById('downloadPath').value
            };

            fetch(API_BASE + '/config/save', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(config)
            })
            .then(() => showAlert('Config saved', 'success'))
            .catch(() => showAlert('Failed to save config', 'error'));
        }

        function toggleTerminal() {
            document.getElementById('terminal').classList.toggle('visible');
        }

        function addTerminalLine(text, type = 'log') {
            const terminal = document.getElementById('terminal');
            const line = document.createElement('div');
            line.className = 'terminal-line ' + type;
            line.textContent = text;
            terminal.appendChild(line);
            terminal.scrollTop = terminal.scrollHeight;
        }

        function startSync() {
            const authToken = document.getElementById('authToken').value.trim();
            const playlistUrl = document.getElementById('playlistUrl').value.trim();
            const albumName = document.getElementById('albumName').value.trim();
            const albumArtist = document.getElementById('albumArtist').value.trim();
            const downloadPath = document.getElementById('downloadPath').value.trim();

            if (!authToken || !playlistUrl || !albumName || !downloadPath) {
                showAlert('Please fill in all required fields', 'error');
                return;
            }

            saveConfig();
            document.getElementById('terminal').innerHTML = '';
            document.getElementById('terminal').classList.add('visible');
            document.getElementById('completeBox').style.display = 'none';
            
            const btn = document.getElementById('syncBtn');
            btn.disabled = true;
            btn.textContent = 'Syncing...';
            document.getElementById('statusText').textContent = 'Starting sync...';
            document.getElementById('statusText').className = 'status-value syncing';
            addTerminalLine('Sync started...', 'log');

            fetch(API_BASE + '/sync/start', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ authToken, playlistUrl, albumName, albumArtist, downloadPath })
            })
            .then(response => {
                const reader = response.body.getReader();
                const decoder = new TextDecoder();

                function read() {
                    reader.read().then(({ done, value }) => {
                        if (done) return;
                        const chunk = decoder.decode(value);
                        const lines = chunk.split('\n');
                        lines.forEach(line => {
                            if (line.startsWith('data: ')) {
                                try {
                                    const data = JSON.parse(line.slice(6));
                                    if (data.type === 'log') addTerminalLine(data.message, 'log');
                                    else if (data.type === 'complete') {
                                        document.getElementById('statusText').textContent = 'Complete';
                                        document.getElementById('statusText').className = 'status-value success';
                                        document.getElementById('completeBox').style.display = 'block';
                                        addTerminalLine('Sync complete', 'success');
                                        showAlert('Sync complete - Check Apple Music', 'success');
                                    } else if (data.type === 'error') {
                                        document.getElementById('statusText').textContent = 'Error';
                                        document.getElementById('statusText').className = 'status-value error';
                                        addTerminalLine('Error: ' + data.message, 'error');
                                        showAlert('Error: ' + data.message, 'error');
                                    }
                                } catch (e) {}
                            }
                        });
                        read();
                    });
                }
                read();
            })
            .catch(err => {
                showAlert('Error: ' + err.message, 'error');
                addTerminalLine('Error: ' + err.message, 'error');
            })
            .finally(() => {
                btn.disabled = false;
                btn.textContent = 'Start Sync';
            });
        }

        function showAlert(message, type) {
            const alert = document.getElementById('alert');
            alert.textContent = message;
            alert.className = `alert show ${type}`;
            setTimeout(() => alert.classList.remove('show'), 4000);
        }
    </script>
</body>
</html>
